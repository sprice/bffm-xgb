{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": "src/server",
    "declaration": false
  },
  "include": ["src/server"],
  "exclude": ["src/server/**/*.test.ts"]
}
