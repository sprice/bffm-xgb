# HuggingFace access token (required for `make upload-hf`)
# Create at: https://huggingface.co/settings/tokens
# Needs write permission to the target repository
HF_TOKEN=hf_...

# HuggingFace repository ID (required for `make upload-hf` and `make deploy-web`)
HF_REPO_ID=user_or_org/repo_name

# HuggingFace Space ID (required for `make deploy-web`)
HF_SPACE_ID=user_or_org/space_name

# Pin model downloads to an immutable HF commit (optional, recommended for production)
# HF_REVISION=abc123def456...
# HF_SHA256_CONFIG=sha256_hex_of_config_json
# HF_SHA256_MODEL=sha256_hex_of_model_onnx
