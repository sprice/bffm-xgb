.DS_Store
# Data (downloaded/generated)
data/raw/
data/processed/
*.csv
!artifacts/**/*.csv
*.db
*.sqlite
*.parquet
*.zip

# Models (trained)
models/*/
!models/.gitkeep

# Environment
.env

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Node
node_modules/

# Web app (regenerable)
web/model/
web/dist/
learn/dist/

# Pipeline outputs (regenerable via make all)
artifacts/ipip_bffm_norms.meta.json
artifacts/tuned_params.original.json
artifacts/research_summary.json
artifacts/variants/

# Output (published to HuggingFace Hub)
output/*/
!output/README.md
!output/.gitkeep

# Figures (regenerable)
figures/*.png
figures/*.pdf
figures/manifest.json
!figures/.gitkeep

# Remote pipeline
.git-hash
pipeline.log
pipeline-timing.log
logs/
.pipeline-exit-code
.pipeline-checkpoints/
.backup/

# Claude settings
.claude/settings.local.json

# Terraform
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfvars
infra/cpu/.terraform/
infra/cpu/*.tfstate
infra/cpu/*.tfstate.backup
infra/cpu/.terraform.lock.hcl
infra/cpu/terraform.tfvars
infra/gpu/.terraform/
infra/gpu/*.tfstate
infra/gpu/*.tfstate.backup
infra/gpu/.terraform.lock.hcl
infra/gpu/terraform.tfvars
*.tfstate.lock.info

# Web
web/.impeccable.md
